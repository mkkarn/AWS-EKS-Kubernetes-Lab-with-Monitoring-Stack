################################################################################
# Example tfvars for Dev Environment
################################################################################

# Project and environment
project_name = "eks-lab"
environment  = "dev"

# VPC settings
vpc_cidr = "10.0.0.0/16"
az_count = 3

# EKS cluster
cluster_version = "1.29"

# Node group configuration
node_groups = {
  default = {
    desired_capacity = 3
    max_capacity     = 5
    min_capacity     = 3
    instance_type    = "m5.large"   # 2 vCPU, 8 GiB RAM per node
  }
  monitoring = {
    desired_capacity = 2
    max_capacity     = 3
    min_capacity     = 2
    instance_type    = "m5.xlarge"  # 4 vCPU, 16 GiB RAM per node
  }
}

# Monitoring stack
grafana_admin_password  = "ChangeMe123!"
prometheus_storage_size = "30Gi"
grafana_storage_size    = "10Gi"

# Logging stack
elasticsearch_storage_size = "100Gi"
elasticsearch_replicas     = 2
storage_class_name         = "gp3"

